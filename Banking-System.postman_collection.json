{
  "info": {
    "name": "Banking System API",
    "description": "Colección completa de endpoints para el Sistema Bancario - Spring Boot\n\nAPI REST para la gestión de clientes, cuentas, préstamos y transferencias en un sistema bancario con autenticación JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"analyst_user\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Autentica un usuario y obtiene un token JWT para acceder a los endpoints protegidos."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set(\"token\", res.token);",
                  "    pm.collectionVariables.set(\"username\", res.username);",
                  "    pm.collectionVariables.set(\"role\", res.role);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
